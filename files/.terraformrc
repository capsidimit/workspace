provider_installation {
  filesystem_mirror {
    path = "~/.terraform.d/plugins"
    include = ["basis/*/*", "opennebula/*/*"]
  }

  network_mirror {
    url = "https://terraform-mirror.yandexcloud.net/"
    include = ["registry.terraform.io/*/*","registry.opentofu.org/*/*"]
  }

  network_mirror {
    url = "https://hashicorp-releases.yandexcloud.net/"
    include = ["hashicorp/*/*"]
  }

  direct {
    exclude = ["registry.terraform.io/*/*","registry.opentofu.org/*/*","basis/*/*","hashicorp/*/*"]
  }
}